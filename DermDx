<div class="m-ovl" id="mOvl">
  <div class="modal">
    <button class="m-close" onclick="closeModal()">✕</button>
    <div class="modal-title">Dermatology Report</div>
    <div class="modal-sub">Generated by DermDx</div>
    <div class="rbox" id="reportBox"></div>
    <div class="m-acts">
