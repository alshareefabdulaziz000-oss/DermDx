<script>
var sex = '', preg = '', loc = '', dur = '';
var syms = {};
var imgBase64 = '';
var dxStore = {};
var reportText = '';

// IMAGE
function handleImg(input) {
  var file = input.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    imgBase64 = e.target.result.split(',')[1];
    var prev = document.getElementById('previewImg');
    prev.src = e.target.result;
    prev.style.display = 'block';
    document.getElementById('changeBtn').style.display = 'block';
    var zone = document.getElementById('uploadZone');
    zone.classList.add('has-img');
    zone.querySelector('.upload-icon').style.display = 'none';
    zone.querySelector('.upload-title').style.display = 'none';
    zone.querySelector('.upload-hint').style.display = 'none';
  };
  reader.readAsDataURL(file);
}

function setSex(s) {
  sex = s;
  document.getElementById('tMale').classList.toggle('on', s === 'Male');
  document.getElementById('tFemale').classList.toggle('on', s === 'Female');
  document.getElementById('pregWrap').style.display = s === 'Female' ? 'block' : 'none';
  if (s === 'Male') preg = '';
}

function setPreg(p) {
  preg = p;
  document.getElementById('tPreg').classList.toggle('on', p === 'Pregnant');
  document.getElementById('tNotPreg').classList.toggle('on', p === 'Not Pregnant');
}

function setLoc(btn, l) {
  loc = l;
  document.querySelectorAll('.loc-btn').forEach(function(b) { b.classList.remove('on'); });
  btn.classList.add('on');
}

function setDur(btn, d) {
  dur = d;
  document.querySelectorAll('.dur-btn').forEach(function(b) { b.classList.remove('on'); });
  btn.classList.add('on');
}

function setSym(btn, key, val) {
  syms[key] = val;
  var parent = btn.closest('.sym-btns');
  parent.querySelectorAll('.sym-btn.yes').forEach(function(b) { b.classList.remove('on'); });
  parent.querySelectorAll('.sym-btn.no').forEach(function(b) { b.classList.remove('on'); });
  btn.classList.add('on');
}

function openDrawer() {
  var k = localStorage.getItem('dermdx_key') || '';
  document.getElementById('keyInput').value = k;
  document.getElementById('drawer').classList.add('open');
  document.getElementById('ovl').classList.add('show');
}
function closeDrawer() {
  document.getElementById('drawer').classList.remove('open');
  document.getElementById('ovl').classList.remove('show');
}
function saveKey() {
  var k = document.getElementById('keyInput').value.trim();
  localStorage.setItem('dermdx_key', k);
  document.getElementById('keyOk').style.display = 'block';
  setTimeout(function() { document.getElementById('keyOk').style.display = 'none'; closeDrawer(); }, 1500);
}

function showErr(title, msg) {
  document.getElementById('errTitle').textContent = title;
  document.getElementById('errMsg').textContent = ' ' + msg;
  document.getElementById('errBox').classList.add('show');
}
function hideErr() { document.getElementById('errBox').classList.remove('show'); }

function symStr() {
  var keys = { itch: 'Itching', pain: 'Pain', burn: 'Burning', bleed: 'Bleeding', ulcer: 'Ulceration', spread: 'Spreading', grow: 'Growing', sun: 'Sun sensitivity', family: 'Family history of skin disease', meds: 'Currently on medications' };
  var yes = [], no = [];
  Object.keys(keys).forEach(function(k) {
    if (syms[k] === 'yes') yes.push(keys[k]);
    else if (syms[k] === 'no') no.push(keys[k]);
  });
  var result = '';
  if (yes.length) result += 'Present: ' + yes.join(', ') + '. ';
  if (no.length) result += 'Absent: ' + no.join(', ') + '.';
  return result || 'Not specified';
}

// ISIC API
async function fetchISIC(diagnosis) {
  try {
    var url = 'https://api.isic-archive.com/api/v2/images/?diagnosis=' + encodeURIComponent(diagnosis) + '&limit=3&offset=0';
    var res = await fetch(url);
    if (!res.ok) return [];
    var data = await res.json();
    return data.results || [];
  } catch(e) { return []; }
}

async function analyze() {
  hideErr();
  var age = document.getElementById('ageInput').value.trim();
  var extra = document.getElementById('extra').value.trim();
  var apiKey = localStorage.getItem('dermdx_key') || '';

  if (!imgBase64) { showErr('No Image', 'Please upload a photo of the lesion.'); return; }
  if (!age) { showErr('Missing Field', 'Please enter the patient age.'); return; }
  if (!sex) { showErr('Missing Field', 'Please select patient sex.'); return; }
  if (!loc) { showErr('Missing Field', 'Please select lesion location.'); return; }
  if (!dur) { showErr('Missing Field', 'Please select lesion duration.'); return; }
  if (!apiKey) { showErr('No API Key', 'Tap ⚙ and enter your Groq API key from console.groq.com'); return; }

  var pregStr = sex === 'Female' ? (preg || 'Pregnancy status unknown') : '';
  var patientStr = age + ' year-old ' + sex + (pregStr ? ', ' + pregStr : '');
  var symptomsStr = symStr();

  document.getElementById('goBtn').disabled = true;
  document.getElementById('loadingEl').classList.add('show');
  document.getElementById('resultsEl').classList.remove('show');

  // Animate loading steps
  var steps = ['step1','step2','step3'];
  var si = 0;
  var stepInt = setInterval(function() {
    steps.forEach(function(s) { document.getElementById(s).classList.remove('active'); });
    if (si < steps.length) { document.getElementById(steps[si]).classList.add('active'); si++; }
  }, 2000);

  var prompt =
    'You are a board-certified dermatologist. Base ALL answers strictly on AAD (American Academy of Dermatology), NICE Guidelines, BAD (British Association of Dermatology), UpToDate, and Fitzpatrick\'s Dermatology.\n\n' +
    'Patient: ' + patientStr + '\n' +
    'Lesion Location: ' + loc + '\n' +
    'Duration: ' + dur + '\n' +
    'Symptoms: ' + symptomsStr + '\n' +
    (extra ? 'Additional Notes: ' + extra + '\n' : '') +
    '\nAn image of the lesion has been provided. Analyze it carefully.\n\n' +
    'Based on the image + clinical data, provide:\n' +
    '1. Visual features you observe (color, border, texture, size estimation, morphology)\n' +
    '2. Top 3 differential diagnoses with likelihood percentages\n' +
    '3. For each: exact treatment with drug name + dose + route + duration per guidelines\n' +
    '4. Clinical decision pathway to differentiate between these diagnoses\n\n' +
    'Return ONLY raw JSON, no markdown:\n' +
    '{"visual_features":"describe what you see in the image","diagnoses":[{"rank":1,"name":"","likelihood":0,"first_line":"EXACT drug + dose + route + duration per AAD/BAD/NICE","alternatives":"EXACT alternative + dose + reason","workup":"Specific tests with guideline citation e.g. Skin biopsy - punch biopsy 4mm (AAD Guidelines 2023), KOH preparation (BAD 2022), Wood\'s lamp examination","guideline":"Exact guideline + year"}],"pathway":{"summary":"2-3 sentences on how to differentiate these diagnoses clinically","steps":[{"step":1,"test":"Exact test","if_positive":"→ Supports Dx1 because [reason]. Next: [action]","if_negative":"→ Rules out Dx1. Consider Dx2. Next: [action]"},{"step":2,"test":"Exact test","if_positive":"→ Confirms Dx2. Start [treatment]","if_negative":"→ Unlikely Dx2. Proceed to step 3"},{"step":3,"test":"Exact test","if_positive":"→ Dx3 confirmed","if_negative":"→ Refer to dermatologist for further evaluation"}]}}';

  try {
    var res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + apiKey },
      body: JSON.stringify({
        model: 'meta-llama/llama-4-scout-17b-16e-instruct',
        messages: [{
          role: 'user',
          content: [
            { type: 'image_url', image_url: { url: 'data:image/jpeg;base64,' + imgBase64 } },
            { type: 'text', text: prompt }
          ]
        }],
        temperature: 0.2,
        max_tokens: 3000
      })
    });

    var data = await res.json();
    if (data.error) throw new Error(data.error.message || 'API error');

    var raw = data.choices[0].message.content;
    raw = raw.replace(/```json/g,'').replace(/```/g,'').trim();
    var match = raw.match(/\{[\s\S]*\}/);
    if (!match) throw new Error('Invalid response format');
    var parsed = JSON.parse(match[0]);
    if (!parsed.diagnoses || !parsed.diagnoses.length) throw new Error('No diagnoses returned');

    clearInterval(stepInt);

    // Fetch ISIC similar images for top diagnosis
    var simImages = await fetchISIC(parsed.diagnoses[0].name);

    document.getElementById('loadingEl').classList.remove('show');
    document.getElementById('goBtn').disabled = false;

    var ctx = { patientStr, symptomsStr, loc, dur, extra, visual: parsed.visual_features || '' };
    dxStore = { diagnoses: parsed.diagnoses, ctx };
    renderResults(parsed.diagnoses, parsed.pathway, parsed.visual_features, simImages, ctx);

  } catch(e) {
    clearInterval(stepInt);
    document.getElementById('loadingEl').classList.remove('show');
    document.getElementById('goBtn').disabled = false;
    showErr('Analysis Failed', e.message || 'Please check your API key and try again.');
  }
}

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function renderResults(diagnoses, pathway, visual, simImages, ctx) {
  // Similar images
  var simGrid = document.getElementById('simGrid');
  simGrid.innerHTML = '';
  if (simImages && simImages.length) {
    simImages.forEach(function(img) {
      var div = document.createElement('div');
      div.className = 'sim-img';
      var diagnosis = (img.metadata && img.metadata.diagnosis) ? img.metadata.diagnosis : diagnoses[0].name;
      div.innerHTML = '<img src="' + img.files.thumbnail_256.url + '" alt="ISIC"><div class="sim-badge">' + esc(diagnosis) + '</div>';
      simGrid.appendChild(div);
    });
    document.getElementById('simNote').textContent = 'Matching cases from ISIC Archive — ' + simImages.length + ' similar lesions found';
  } else {
    document.getElementById('simNote').textContent = 'ISIC Archive searched — analysis based on clinical guidelines';
  }

  // Visual features
  if (visual) {
    var vDiv = document.createElement('div');
    vDiv.style.cssText = 'background:#fff;border:1px solid var(--border);border-radius:12px;padding:16px 18px;margin-bottom:16px;font-size:13.5px;color:#57534e;line-height:1.7;';
    vDiv.innerHTML = '<div style="font-family:var(--mono);font-size:9px;letter-spacing:.14em;color:var(--dim);text-transform:uppercase;margin-bottom:6px;">Visual Analysis</div>' + esc(visual);
    simGrid.after(vDiv);
  }

  // DX cards
  var container = document.getElementById('cards');
  container.innerHTML = '';
  var labels = ['1st','2nd','3rd'];
  diagnoses.slice(0,3).forEach(function(dx, i) {
    var div = document.createElement('div');
    div.className = 'dx dx' + (i+1);
    div.innerHTML =
      '<div class="dx-head"><div class="dx-name">' + esc(dx.name) + '</div><div class="rank-chip">' + labels[i] + '</div></div>' +
      '<div class="prob-row"><div class="prob-track"><div class="prob-fill" data-w="' + (dx.likelihood||0) + '"></div></div><div class="prob-num">' + (dx.likelihood||'—') + '%</div></div>' +
      '<div class="tx"><div class="tx-head"><span class="tx-lbl">First-line Treatment</span><span class="g-badge">' + esc(dx.guideline||'') + '</span></div><div class="tx-body">' + esc(dx.first_line||'') + '</div></div>' +
      '<div class="tx"><div class="tx-head"><span class="tx-lbl">Alternative Treatment</span></div><div class="tx-body">' + esc(dx.alternatives||'') + '</div></div>' +
      '<div class="tx"><div class="tx-head"><span class="tx-lbl" style="color:var(--green)">Recommended Workup</span></div><div class="tx-body" style="color:var(--green)">' + esc(dx.workup||'') + '</div></div>' +
      '<button class="sel-btn" onclick="selectDx(' + i + ')">Select this Diagnosis →</button>';
    container.appendChild(div);
  });

  setTimeout(function() {
    document.querySelectorAll('.prob-fill').forEach(function(b) { b.style.width = b.dataset.w + '%'; });
  }, 80);

  // Pathway
  var pathSection = document.getElementById('pathwaySection');
  var pathContent = document.getElementById('pathwayContent');
  if (pathway && pathway.steps && pathway.steps.length) {
    var html = '';
    if (pathway.summary) {
      html += '<div class="pathway-card" style="border-left-color:var(--silver);margin-bottom:12px;">' +
        '<div class="pathway-title" style="color:var(--muted)">Clinical Summary</div>' +
        '<div class="pathway-summary">' + esc(pathway.summary) + '</div></div>';
    }
    html += '<div class="pathway-card"><div class="pathway-title">Step-by-Step Decision Pathway</div>';
    pathway.steps.forEach(function(s) {
      html += '<div class="pathway-step">' +
        '<div class="step-num">' + s.step + '</div>' +
        '<div class="step-body">' +
          '<div class="step-test">' + esc(s.test||'') + '</div>' +
          '<div class="step-logic"><span class="if-pos">✓ If Positive: </span>' + esc(s.if_positive||'') + '</div>' +
          '<div class="step-logic"><span class="if-neg">✗ If Negative: </span>' + esc(s.if_negative||'') + '</div>' +
        '</div></div>';
    });
    html += '</div>';
    pathContent.innerHTML = html;
    pathSection.style.display = 'block';
  } else {
    pathSection.style.display = 'none';
  }

  document.getElementById('resultsEl').classList.add('show');
  document.getElementById('resultsEl').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function selectDx(i) {
  var dx = dxStore.diagnoses[i];
  var ctx = dxStore.ctx;
  var date = new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
  reportText =
'DERMATOLOGY REPORT\n' +
'─'.repeat(44) + '\n' +
'Date: ' + date + '\n\n' +
'PATIENT\n  ' + ctx.patientStr + '\n\n' +
'LESION DETAILS\n' +
'  Location : ' + ctx.loc + '\n' +
'  Duration : ' + ctx.dur + '\n' +
'  Symptoms : ' + ctx.symptomsStr + '\n\n' +
(ctx.visual ? 'VISUAL ANALYSIS\n  ' + ctx.visual + '\n\n' : '') +
'DIAGNOSIS\n  ' + dx.name + '\n  Likelihood: ' + dx.likelihood + '%\n\n' +
'TREATMENT PLAN\n\n' +
'  First-line:\n  ' + dx.first_line + '\n\n' +
'  Alternative:\n  ' + dx.alternatives + '\n\n' +
'  Recommended Workup:\n  ' + (dx.workup||'N/A') + '\n\n' +
'  Guideline Reference: ' + (dx.guideline||'') + '\n\n' +
'─'.repeat(44) + '\n' +
'Physician Signature: _______________\n' +
'Date: _____________________________';

  document.getElementById('reportBox').textContent = reportText;
  document.getElementById('mOvl').classList.add('show');
}

function copyReport() {
  navigator.clipboard.writeText(reportText).then(function() {
    var btn = document.getElementById('copyBtn');
    btn.textContent = '✓ Copied!';
    setTimeout(function() { btn.textContent = 'Copy Report'; }, 2000);
  });
}

function closeModal() { document.getElementById('mOvl').classList.remove('show'); }

function newCase() {
  closeModal();
  document.getElementById('resultsEl').classList.remove('show');
  document.getElementById('previewImg').style.display = 'none';
  document.getElementById('changeBtn').style.display = 'none';
  var zone = document.getElementById('uploadZone');
  zone.classList.remove('has-img');
  zone.querySelector('.upload-icon').style.display = 'block';
  zone.querySelector('.upload-title').style.display = 'block';
  zone.querySelector('.upload-hint').style.display = 'block';
  imgBase64 = ''; sex = ''; preg = ''; loc = ''; dur = ''; syms = {};
  document.getElementById('ageInput').value = '';
  document.getElementById('extra').value = '';
  document.querySelectorAll('.tog,.loc-btn,.dur-btn').forEach(function(b) { b.classList.remove('on'); });
  document.querySelectorAll('.sym-btn').forEach(function(b) { b.classList.remove('on'); });
  document.getElementById('pregWrap').style.display = 'none';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

