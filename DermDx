<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DermDx — AI Dermatology Diagnostic Support</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f5f2ed;
  --bg2: #ffffff;
  --card: #ffffff;
  --border: rgba(0,0,0,0.08);
  --border2: rgba(0,0,0,0.13);
  --text: #1c1917;
  --muted: #78716c;
  --dim: #a8a29e;
  --accent: #b45309;
  --accent2: #d97706;
  --accent-bg: rgba(180,83,9,0.07);
  --green: #15803d;
  --green-bg: rgba(21,128,61,0.07);
  --blue: #1d4ed8;
  --blue-bg: rgba(29,78,216,0.07);
  --red: #dc2626;
  --gold: #92400e;
  --silver: #57534e;
  --bronze: #7c4a1e;
  --display: 'Playfair Display', serif;
  --ui: 'DM Sans', sans-serif;
  --mono: 'DM Mono', monospace;
  --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.06);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.1);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: var(--ui); min-height: 100vh; }

/* HEADER */
.hdr {
background: var(–bg2);
border-bottom: 1px solid var(–border);
padding: 20px 24px;
display: flex;
align-items: center;
justify-content: space-between;
position: sticky; top: 0; z-index: 100;
}
.logo { display: flex; align-items: baseline; gap: 2px; }
.logo-main { font-family: var(–display); font-size: 26px; font-weight: 500; color: var(–text); }
.logo-main em { font-style: italic; color: var(–accent); }
.logo-sub { font-family: var(–mono); font-size: 9px; letter-spacing: .2em; color: var(–dim); text-transform: uppercase; margin-left: 10px; }
.icon-btn { background: none; border: 1px solid var(–border2); border-radius: 8px; padding: 8px 10px; cursor: pointer; color: var(–muted); transition: all .2s; }
.icon-btn:hover { border-color: var(–accent); color: var(–accent); }

/* WRAP */
.wrap { max-width: 680px; margin: 0 auto; padding: 32px 22px 100px; }

/* UPLOAD ZONE */
.upload-zone {
border: 2px dashed var(–border2);
border-radius: 18px;
padding: 48px 24px;
text-align: center;
cursor: pointer;
transition: all .25s;
background: var(–bg2);
margin-bottom: 28px;
position: relative;
overflow: hidden;
}
.upload-zone:hover { border-color: var(–accent); background: var(–accent-bg); }
.upload-zone.has-img { padding: 0; border-style: solid; border-color: var(–accent); }
.upload-zone img { width: 100%; max-height: 320px; object-fit: cover; border-radius: 16px; display: block; }
.upload-icon { font-size: 40px; margin-bottom: 12px; }
.upload-title { font-family: var(–display); font-size: 20px; font-weight: 400; color: var(–text); margin-bottom: 6px; }
.upload-hint { font-size: 13px; color: var(–dim); }
.upload-change {
position: absolute; bottom: 12px; right: 12px;
background: rgba(0,0,0,0.6); color: #fff;
border: none; border-radius: 8px; padding: 6px 12px;
font-family: var(–ui); font-size: 12px; cursor: pointer;
}
input[type=file] { display: none; }

/* FORM */
.fg { margin-bottom: 22px; }
.fl { font-family: var(–mono); font-size: 9.5px; letter-spacing: .17em; color: var(–muted); text-transform: uppercase; margin-bottom: 9px; display: flex; align-items: center; gap: 6px; }
.fl .req { color: var(–accent); } .fl .opt { color: var(–dim); font-size: 9px; }

input[type=number], textarea, select {
width: 100%; background: var(–bg2); border: 1px solid var(–border);
color: var(–text); font-family: var(–ui); font-size: 14px; line-height: 1.6;
padding: 12px 14px; border-radius: 11px; outline: none;
transition: border-color .2s, box-shadow .2s; resize: none; appearance: none;
}
input[type=number]:focus, textarea:focus, select:focus {
border-color: var(–accent); box-shadow: 0 0 0 3px var(–accent-bg);
}
textarea::placeholder, input::placeholder { color: var(–dim); font-size: 13px; }

/* TOGGLE */
.tog-row { display: flex; gap: 8px; flex-wrap: wrap; }
.tog {
padding: 10px 18px; background: var(–bg2); border: 1px solid var(–border);
color: var(–muted); border-radius: 9px; font-family: var(–ui); font-size: 13px;
font-weight: 500; cursor: pointer; transition: all .18s;
}
.tog.on { background: var(–accent-bg); border-color: var(–accent); color: var(–accent); }

/* SYMPTOM GRID */
.sym-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.sym-item {
display: flex; align-items: center; justify-content: space-between;
background: var(–bg2); border: 1px solid var(–border);
border-radius: 10px; padding: 11px 14px; gap: 8px;
}
.sym-label { font-size: 13.5px; color: var(–text); }
.sym-btns { display: flex; gap: 5px; }
.sym-btn {
padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 500;
cursor: pointer; border: 1px solid var(–border); background: var(–bg);
color: var(–muted); transition: all .15s; font-family: var(–ui);
}
.sym-btn.yes.on { background: var(–green-bg); border-color: var(–green); color: var(–green); }
.sym-btn.no.on { background: rgba(220,38,38,0.07); border-color: var(–red); color: var(–red); }

/* LOCATION */
.loc-grid { display: flex; flex-wrap: wrap; gap: 7px; }
.loc-btn {
padding: 8px 14px; background: var(–bg2); border: 1px solid var(–border);
border-radius: 8px; font-family: var(–ui); font-size: 13px; color: var(–muted);
cursor: pointer; transition: all .15s;
}
.loc-btn.on { background: var(–blue-bg); border-color: var(–blue); color: var(–blue); }

/* DURATION */
.dur-row { display: flex; gap: 8px; }
.dur-btn {
flex: 1; padding: 10px; text-align: center; background: var(–bg2);
border: 1px solid var(–border); border-radius: 9px; font-family: var(–ui);
font-size: 13px; color: var(–muted); cursor: pointer; transition: all .15s;
}
.dur-btn.on { background: var(–accent-bg); border-color: var(–accent); color: var(–accent); }

/* GO BUTTON */
.go {
width: 100%; padding: 17px; background: var(–accent);
color: #fff; border: none; border-radius: 13px; font-family: var(–ui);
font-size: 15px; font-weight: 500; cursor: pointer; transition: all .25s;
margin-top: 6px; letter-spacing: .02em;
}
.go:hover { background: #92400e; box-shadow: 0 8px 24px rgba(180,83,9,0.3); transform: translateY(-1px); }
.go:disabled { opacity: .4; cursor: not-allowed; transform: none; box-shadow: none; }

/* ERROR */
.err { display: none; margin-top: 14px; background: rgba(220,38,38,0.06); border: 1px solid rgba(220,38,38,0.2); border-radius: 11px; padding: 14px 16px; color: #b91c1c; font-size: 13px; line-height: 1.6; }
.err.show { display: block; }
.err strong { display: block; font-family: var(–mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; margin-bottom: 4px; }

/* LOADING */
.loading { display: none; text-align: center; padding: 72px 0; }
.loading.show { display: block; }
.spin { width: 44px; height: 44px; margin: 0 auto 18px; border: 1.5px solid var(–border2); border-top-color: var(–accent); border-radius: 50%; animation: spin .9s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-label { font-family: var(–mono); font-size: 11px; letter-spacing: .12em; color: var(–muted); }
.loading-steps { margin-top: 16px; }
.loading-step { font-size: 12px; color: var(–dim); margin: 4px 0; transition: color .3s; }
.loading-step.active { color: var(–accent); font-weight: 500; }

/* RESULTS */
.results { display: none; margin-top: 44px; }
.results.show { display: block; }
.rhdr { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(–border); }
.rl { font-family: var(–mono); font-size: 9px; letter-spacing: .2em; color: var(–dim); text-transform: uppercase; }
.rline { flex: 1; height: 1px; background: var(–border); }

/* SIMILAR IMAGES */
.sim-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 10px; }
.sim-img { border-radius: 10px; overflow: hidden; aspect-ratio: 1; position: relative; }
.sim-img img { width: 100%; height: 100%; object-fit: cover; }
.sim-badge { position: absolute; bottom: 6px; left: 6px; right: 6px; background: rgba(0,0,0,0.7); color: #fff; font-size: 9px; font-family: var(–mono); padding: 3px 6px; border-radius: 4px; text-align: center; line-height: 1.3; }
.sim-note { font-family: var(–mono); font-size: 9px; color: var(–dim); text-align: center; margin-bottom: 20px; letter-spacing: .08em; }

/* DX CARDS */
.dx {
background: var(–card); border: 1px solid var(–border);
border-radius: 15px; padding: 22px 24px; margin-bottom: 14px;
position: relative; overflow: hidden; box-shadow: var(–shadow);
animation: up .4s ease backwards;
}
.dx::before { content: ‘’; position: absolute; top: 0; left: 0; width: 3px; height: 100%; border-radius: 3px 0 0 3px; }
.dx1::before { background: var(–gold); } .dx2::before { background: var(–silver); } .dx3::before { background: var(–bronze); }
.dx1 { animation-delay: .05s; } .dx2 { animation-delay: .15s; } .dx3 { animation-delay: .25s; }
@keyframes up { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

.dx-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 14px; }
.dx-name { font-family: var(–display); font-size: 22px; font-weight: 400; color: var(–text); line-height: 1.2; flex: 1; }
.rank-chip { font-family: var(–mono); font-size: 9px; padding: 4px 10px; border-radius: 20px; flex-shrink: 0; }
.dx1 .rank-chip { background: rgba(146,64,14,0.1); color: var(–gold); border: 1px solid rgba(146,64,14,0.2); }
.dx2 .rank-chip { background: rgba(87,83,78,0.1); color: var(–silver); border: 1px solid rgba(87,83,78,0.2); }
.dx3 .rank-chip { background: rgba(124,74,30,0.1); color: var(–bronze); border: 1px solid rgba(124,74,30,0.2); }

.prob-row { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
.prob-track { flex: 1; height: 3px; background: var(–border); border-radius: 2px; overflow: hidden; }
.prob-fill { height: 100%; border-radius: 2px; width: 0; transition: width 1.1s cubic-bezier(.4,0,.2,1); }
.dx1 .prob-fill { background: linear-gradient(90deg, #92400e, #d97706); }
.dx2 .prob-fill { background: linear-gradient(90deg, #57534e, #a8a29e); }
.dx3 .prob-fill { background: linear-gradient(90deg, #7c4a1e, #b07040); }
.prob-num { font-family: var(–mono); font-size: 12px; color: var(–muted); min-width: 34px; text-align: right; }

.tx { margin-bottom: 15px; }
.tx-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.tx-lbl { font-family: var(–mono); font-size: 9px; letter-spacing: .14em; color: var(–dim); text-transform: uppercase; }
.g-badge { font-family: var(–mono); font-size: 9px; padding: 2px 8px; border-radius: 20px; background: var(–accent-bg); border: 1px solid rgba(180,83,9,0.2); color: var(–accent); }
.tx-body { font-size: 13.5px; color: #57534e; line-height: 1.7; }

.sel-btn {
width: 100%; margin-top: 16px; padding: 11px;
background: transparent; border: 1px solid var(–border2);
color: var(–muted); border-radius: 9px; font-family: var(–ui);
font-size: 13px; font-weight: 500; cursor: pointer; transition: all .18s;
}
.sel-btn:hover { border-color: var(–accent); color: var(–accent); background: var(–accent-bg); }

/* PATHWAY */
.pathway-card {
background: var(–bg2); border: 1px solid var(–border);
border-left: 3px solid var(–accent); border-radius: 14px;
padding: 22px 24px; margin-bottom: 12px; box-shadow: var(–shadow);
animation: up .4s ease .35s backwards;
}
.pathway-title { font-family: var(–mono); font-size: 9px; letter-spacing: .18em; color: var(–accent); text-transform: uppercase; margin-bottom: 14px; display: flex; align-items: center; gap: 7px; }
.pathway-title::before { content: ‘’; display: inline-block; width: 5px; height: 5px; background: var(–accent); border-radius: 50%; }
.pathway-summary { font-size: 14px; color: #57534e; line-height: 1.75; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid var(–border); }
.pathway-step { display: flex; gap: 14px; margin-bottom: 18px; align-items: flex-start; }
.pathway-step:last-child { margin-bottom: 0; }
.step-num { font-family: var(–mono); font-size: 10px; color: #fff; background: var(–accent); width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
.step-body { flex: 1; }
.step-test { font-size: 14px; font-weight: 500; color: var(–text); margin-bottom: 6px; }
.step-logic { font-size: 13px; color: #57534e; line-height: 1.65; margin-top: 4px; }
.if-pos { color: var(–green); font-weight: 500; }
.if-neg { color: var(–red); font-weight: 500; }

/* MODAL */
.m-ovl { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 300; align-items: center; justify-content: center; padding: 22px; backdrop-filter: blur(6px); }
.m-ovl.show { display: flex; }
.modal { background: var(–bg2); border: 1px solid var(–border2); border-radius: 17px; padding: 30px; max-width: 560px; width: 100%; max-height: 88vh; overflow-y: auto; position: relative; animation: pop .25s cubic-bezier(.34,1.56,.64,1); box-shadow: var(–shadow-lg); }
@keyframes pop { from { opacity: 0; transform: scale(.94) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
.modal-title { font-family: var(–display); font-size: 22px; font-weight: 400; margin-bottom: 3px; }
.modal-sub { font-family: var(–mono); font-size: 9px; letter-spacing: .18em; color: var(–dim); text-transform: uppercase; }
.rbox { background: var(–bg); border: 1px solid var(–border); border-radius: 11px; padding: 18px 20px; margin: 18px 0; font-family: var(–mono); font-size: 11px; line-height: 2; color: var(–muted); white-space: pre-wrap; word-break: break-word; }
.m-acts { display: flex; gap: 10px; }
.m-btn { flex: 1; padding: 12px; border-radius: 10px; font-family: var(–ui); font-size: 13px; font-weight: 500; cursor: pointer; transition: all .18s; border: 1px solid var(–border2); background: transparent; color: var(–muted); }
.m-btn.pri { background: var(–accent); color: #fff; border-color: transparent; }
.m-btn:hover { opacity: .82; }
.m-close { position: absolute; top: 14px; right: 14px; background: none; border: none; color: var(–muted); cursor: pointer; font-size: 16px; }

/* DRAWER */
.ovl { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; }
.ovl.show { display: block; }
.drawer { position: fixed; right: -320px; top: 0; bottom: 0; width: 300px; background: var(–bg2); border-left: 1px solid var(–border); z-index: 201; padding: 28px 22px; transition: right .3s cubic-bezier(.4,0,.2,1); overflow-y: auto; }
.drawer.open { right: 0; }
.drawer-title { font-family: var(–display); font-size: 20px; font-weight: 400; margin-bottom: 20px; }
.drawer-close { position: absolute; top: 16px; right: 16px; background: none; border: none; color: var(–muted); cursor: pointer; font-size: 16px; }
.save-btn { width: 100%; padding: 12px; background: var(–accent); color: #fff; border: none; border-radius: 10px; font-family: var(–ui); font-size: 14px; font-weight: 500; cursor: pointer; margin-top: 8px; }
.key-ok { display: none; font-family: var(–mono); font-size: 10px; color: var(–green); text-align: center; margin-top: 10px; letter-spacing: .1em; }
.drawer-note { font-size: 12px; color: var(–dim); line-height: 1.65; margin-top: 16px; }
.key-link { color: var(–accent); font-size: 12px; }

@media (max-width: 520px) {
.sym-grid { grid-template-columns: 1fr; }
.sim-grid { grid-template-columns: repeat(3, 1fr); }
.dur-row { flex-wrap: wrap; }
.dur-btn { flex: none; width: calc(50% - 4px); }
}
</style>

</head>
<body>

<header class="hdr">
  <div class="logo">
    <div class="logo-main">Derm<em>Dx</em></div>
    <div class="logo-sub">Dermatology AI</div>
  </div>
  <button class="icon-btn" onclick="openDrawer()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
  </button>
</header>

<div class="wrap">

  <!-- UPLOAD -->

  <div class="upload-zone" id="uploadZone" onclick="document.getElementById('imgInput').click()">
    <div class="upload-icon">🔬</div>
    <div class="upload-title">Upload Lesion Photo</div>
    <div class="upload-hint">Tap to select image — clear, well-lit, close-up</div>
    <img id="previewImg" style="display:none">
    <button class="upload-change" id="changeBtn" style="display:none" onclick="event.stopPropagation(); document.getElementById('imgInput').click()">Change Photo</button>
  </div>
  <input type="file" id="imgInput" accept="image/*" onchange="handleImg(this)">

  <!-- PATIENT -->

  <div class="fg">
    <div class="fl">Age <span class="req">*</span></div>
    <input type="number" id="ageInput" min="0" max="120" placeholder="e.g. 34" style="max-width:160px">
  </div>

  <div class="fg">
    <div class="fl">Patient Sex <span class="req">*</span></div>
    <div class="tog-row">
      <button class="tog" id="tMale" onclick="setSex('Male')">Male</button>
      <button class="tog" id="tFemale" onclick="setSex('Female')">Female</button>
    </div>
    <div id="pregWrap" style="display:none; margin-top:14px;">
      <div class="fl">Pregnancy Status</div>
      <div class="tog-row">
        <button class="tog" id="tPreg" onclick="setPreg('Pregnant')">Pregnant</button>
        <button class="tog" id="tNotPreg" onclick="setPreg('Not Pregnant')">Not Pregnant</button>
      </div>
    </div>
  </div>

  <!-- LOCATION -->

  <div class="fg">
    <div class="fl">Lesion Location <span class="req">*</span></div>
    <div class="loc-grid">
      <button class="loc-btn" onclick="setLoc(this,'Face')">Face</button>
      <button class="loc-btn" onclick="setLoc(this,'Scalp')">Scalp</button>
      <button class="loc-btn" onclick="setLoc(this,'Neck')">Neck</button>
      <button class="loc-btn" onclick="setLoc(this,'Chest')">Chest</button>
      <button class="loc-btn" onclick="setLoc(this,'Back')">Back</button>
      <button class="loc-btn" onclick="setLoc(this,'Abdomen')">Abdomen</button>
      <button class="loc-btn" onclick="setLoc(this,'Arms')">Arms</button>
      <button class="loc-btn" onclick="setLoc(this,'Hands')">Hands</button>
      <button class="loc-btn" onclick="setLoc(this,'Legs')">Legs</button>
      <button class="loc-btn" onclick="setLoc(this,'Feet')">Feet</button>
      <button class="loc-btn" onclick="setLoc(this,'Genitalia')">Genitalia</button>
      <button class="loc-btn" onclick="setLoc(this,'Nails')">Nails</button>
    </div>
  </div>

  <!-- DURATION -->

  <div class="fg">
    <div class="fl">Duration <span class="req">*</span></div>
    <div class="dur-row">
      <button class="dur-btn" onclick="setDur(this,'Days')">Days</button>
      <button class="dur-btn" onclick="setDur(this,'Weeks')">Weeks</button>
      <button class="dur-btn" onclick="setDur(this,'Months')">Months</button>
      <button class="dur-btn" onclick="setDur(this,'Years')">Years</button>
    </div>
  </div>

  <!-- SYMPTOMS -->

  <div class="fg">
    <div class="fl">Associated Symptoms <span class="req">*</span></div>
    <div class="sym-grid">
      <div class="sym-item">
        <span class="sym-label">Itching</span>
        <div class="sym-btns">
          <button class="sym-btn yes" onclick="setSym(this,'itch','yes')">Yes</button>
          <button class="sym-btn no" onclick="setSym(this,'itch','no')">No</button>
        </div>
      </div>
      <div class="sym-item">
        <span class="sym-label">Pain</span>
        <div class="sym-btns">
          <button class="sym-btn yes" onclick="setSym(this,'pain','yes')">Yes</button>
          <button class="sym-btn no" onclick="setSym(this,'pain','no')">No</button>
        </div>
      </div>
      <div class="sym-item">
        <span class="sym-label">Burning</span>
        <div class="sym-btns">
          <button class="sym-btn yes" onclick="setSym(this,'burn','yes')">Yes</button>
